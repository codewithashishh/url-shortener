<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

```
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
    }

    body {
        min-height: 100vh;
        padding: 50px;
        background: #f5f0ff;
        color: #2d2340;
    }

    .container {
        max-width: 1000px;
        margin: auto;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    h1 {
        color: #6d4caf;
        font-size: 30px;
    }

    .logout-form {
        margin: 0;
    }

    .logout-btn {
        background: transparent;
        color: #7653b8;
        border: 1px solid #b9a3e3;
    }

    .logout-btn:hover {
        background: #ede3ff;
    }

    .shortener-card {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(109, 76, 175, 0.08);
        margin-bottom: 30px;
    }

    .url-form {
        display: flex;
        gap: 12px;
    }

    input {
        flex: 1;
        padding: 12px 15px;
        font-size: 16px;
        border: 1px solid #d9ccef;
        border-radius: 7px;
        outline: none;
        color: #2d2340;
    }

    input:focus {
        border-color: #8b6bc5;
    }

    input::placeholder {
        color: #9d91ad;
    }

    button {
        padding: 12px 22px;
        border: none;
        border-radius: 7px;
        cursor: pointer;
        font-size: 15px;
        transition: 0.2s;
    }

    .shorten-btn {
        background: #7c5cbf;
        color: white;
    }

    .shorten-btn:hover {
        background: #6849a8;
    }

    .table-container {
        overflow-x: auto;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(109, 76, 175, 0.08);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th,
    td {
        padding: 15px;
        text-align: left;
        border-bottom: 1px solid #eee8f7;
    }

    th {
        background: #7653b8;
        color: white;
        font-weight: 500;
    }

    th:first-child {
        border-radius: 12px 0 0 0;
    }

    th:last-child {
        border-radius: 0 12px 0 0;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover {
        background: #faf7ff;
    }

    a {
        text-decoration: none;
        color: #7653b8;
        font-weight: 500;
    }

    a:hover {
        text-decoration: underline;
    }

    @media (max-width: 600px) {
        body {
            padding: 25px 15px;
        }

        .url-form {
            flex-direction: column;
        }

        .header {
            gap: 15px;
        }

        h1 {
            font-size: 24px;
        }
    }
</style>
```

</head>

<body>

<div class="container">

```
<div class="header">
    <h1>URL Shortener</h1>

    <form action="/user/logout" method="POST" class="logout-form">
        <button type="submit" class="logout-btn">
            Logout
        </button>
    </form>
</div>

<div class="shortener-card">

    <form action="/" method="POST" class="url-form">

        <input
            type="text"
            name="originalUrl"
            placeholder="Enter Original URL"
            required
        >

        <button type="submit" class="shorten-btn">
            Shorten
        </button>

    </form>

</div>

<div class="table-container">

    <table>

        <thead>
            <tr>
                <th>Short URL</th>
                <th>Original URL</th>
                <th>Clicks</th>
            </tr>
        </thead>

        <tbody>

            <% urls.forEach(url => { %>

                <tr>

                    <td>
                        <a href="/<%= url.shortId %>" target="_blank">
                            http://localhost:8000/<%= url.shortId %>
                        </a>
                    </td>

                    <td>
                        <%= url.originalUrl %>
                    </td>

                    <td>
                        <%= url.noOfTimesClicked %>
                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</div>
```

</div>

</body>
</html>
